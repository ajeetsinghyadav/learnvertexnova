      "locked": false,
      "containerId": null,
      "originalText": "pixel → NDC:   nx = 2x/W − 1,   ny = 1 − 2y/H\nsphere:  p = (nx, ny, √(1−r²))  if r ≤ 1\n         p = normalize(nx, ny, 0)  if r > 1",
      "autoResize": false,
      "lineHeight": 1.5
