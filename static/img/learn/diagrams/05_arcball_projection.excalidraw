      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "text": "pixel → NDC:   nx = 2x/W − 1,   ny = 1 − 2y/H\nsphere:  p = (nx, ny, √(1−r²))  if r ≤ 1\n         p = normalize(nx, ny, 0)  if r > 1",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "seed": 71,
      "version": 12,
      "versionNonce": 306952527,
